# --- Raylib C Project .gitignore ---

# Object files and static libs
*.o
*.obj
*.lo
*.a
*.lib

# Shared libraries
*.so
*.dylib
*.dll

# Platform executables
*.exe
*.out
*.elf

# Raylib-generated build files (depending on OS)
*.pdb
*.exp

# Build directories
/build/
/bin/
/dist/
/Debug/
/Release/
/out/

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

# IDEs and editors
.vscode/
.idea/
*.code-workspace

# Temporary and backup files
*~
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Logs and runtime files
*.log
.cache/

# Environment and secrets
.env
.env.local

# Node modules (optional for tooling)
node_modules/

# Optional: ignore generated assets (uncomment if needed)
# *.png
# *.jpg
# *.jpeg
# *.gif
